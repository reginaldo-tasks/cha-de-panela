{
    "buildCommand": "echo 'Monorepo - Deploy cada pasta separadamente'",
    "projects": {
        "backend": {
            "rootDirectory": "backend",
            "buildCommand": "pip install -r requirements.txt",
            "outputDirectory": "",
            "settings": {
                "nodeVersion": "18.x"
            }
        },
        "frontend": {
            "rootDirectory": "frontend",
            "buildCommand": "npm run build",
            "outputDirectory": "dist",
            "settings": {
                "nodeVersion": "18.x"
            }
        }
    }
}