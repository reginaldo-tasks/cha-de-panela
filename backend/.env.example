# Development Settings
DEBUG=True
DJANGO_SETTINGS_MODULE=core.settings

# Secret Keys (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256

# Database
# Development (SQLite)
DATABASE_URL=sqlite:///db.sqlite3

# Production (PostgreSQL on Vercel)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,localhost:8000

# CORS (Allowed Frontend Origins)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:8080

# Production Settings (Vercel)
# DEBUG=False
# ALLOWED_HOSTS=seu-backend.vercel.app
# CORS_ALLOWED_ORIGINS=https://seu-frontend.vercel.app
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
