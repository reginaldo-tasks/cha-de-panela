# =====================================
# Environment Variables - Chá de Panela Backend
# =====================================

# Django Settings
SECRET_KEY=your-django-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
DEBUG=True

# Database Configuration - For Local Development
DB_ENGINE=sqlite3
# For PostgreSQL locally, uncomment and set these:
# DB_ENGINE=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/chapanela

# Django Hosts Configuration
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# CORS - Allowed Frontend Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# =====================================
# Vercel Blob Storage Configuration
# =====================================
# Get S3_READ_WRITE_TOKEN from Vercel dashboard:
# Settings > Environment Variables
S3_READ_WRITE_TOKEN=your-vercel-blob-token-here

# LEGACY: Supabase S3 Storage Configuration (deprecated, use Blob Storage above)
# SUPABASE_S3_ENDPOINT=your-endpoint-here
# SUPABASE_ACCESS_KEY=your-access-key-here
# SUPABASE_SECRET_KEY=your-secret-key-here
# SUPABASE_REGION=your-region-here